#!/bin/bash
set -euo pipefail
. "{{ .chezmoi.sourceDir }}/.chezmoitemplates/lib.sh"

log_section "SSH key setup"

mkdir -p ~/.ssh
chmod 700 ~/.ssh

if [ -f ~/.ssh/id_ed25519 ]; then
    log_skipped "SSH key already exists"
    exit 0
fi

echo -n "Enter passphrase for new SSH key: "
read -rs passphrase
echo

ssh-keygen -t ed25519 \
    -C "$(whoami)@$(hostname -s)" \
    -f ~/.ssh/id_ed25519 \
    -N "$passphrase"

log_changed "SSH key generated"

{{ if eq .chezmoi.os "darwin" -}}
pbcopy < ~/.ssh/id_ed25519.pub
OPEN=open
{{ else -}}
xclip -selection clipboard < ~/.ssh/id_ed25519.pub
OPEN=xdg-open
{{ end -}}

log_ok "Public key copied to clipboard"

$OPEN "https://github.com/settings/ssh/new"
$OPEN "https://gitlab.com/-/user_settings/ssh_keys"
$OPEN "https://codeberg.org/user/settings/keys"

echo "Add your SSH key to each forge, then press Enter to continue."
read -r
